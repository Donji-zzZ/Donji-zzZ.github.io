---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";

const scholar = "https://scholar.google.com/citations?user=9xZXl44AAAAJ&hl=en";
// published-paper links (click a card to open the paper)
const yellowstone = "https://ieeexplore.ieee.org/abstract/document/11475422"; // TODO: paste the IEEE Xplore link here once the TGRS paper is live
const hyperspectral = "https://ieeexplore.ieee.org/abstract/document/11123135";
const matting = "https://link.springer.com/article/10.1007/s00371-025-04002-8";
---

<BaseLayout title="Research" sideBarActiveItemID="research">
  <div>
    <div class="text-3xl w-full font-bold mb-2">Research</div>
    <div class="mb-5 text-lg">
      I apply deep learning to imaging problems across geophysics and the environment — turning measurements into
      images of things the eye can't reach, with uncertainty made explicit where it matters.
    </div>
  </div>

  <HorizontalCard
    title="Probabilistic electromagnetic imaging"
    img="/research/yellow.png"
    desc="A conditional variational autoencoder inverts airborne electromagnetic (AEM) data into a full distribution of resistivity models rather than a single answer — mapping the hydrothermal system beneath Yellowstone with uncertainty made explicit. Published in IEEE TGRS; presented at AGU 2025."
    url={yellowstone}
    badge="IEEE TGRS"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Monitoring carbon underground (CCS)"
    img="/research/pred_all_timesteps_combined.gif"
    desc="Tracking injected CO2 as it moves through a reservoir by combining time-lapse (4D) seismic and gravity with ML surrogate models fast enough to forecast plume migration — current PhD work toward safe, verifiable geologic carbon storage."
    url={scholar}
    badge="Ongoing"
  />

  <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Other imaging work</div>
  </div>

  <HorizontalCard
    title="Hyperspectral methane plume segmentation"
    img="/research/hyperspectral.gif"
    desc="Detecting and delineating methane plumes from hyperspectral imagery using foundation computer-vision models — large-scale environmental sensing. Published in IEEE Access."
    url={hyperspectral}
    badge="IEEE Access"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="AI-powered underwater image processing"
    img="/research/underwater.gif"
    desc="A mobile platform and learning-based methods for restoring and enhancing degraded underwater imagery, including multi-color-space correction and fusion. Presented at OTC 2025; ICEIECT 2023."
    url={scholar}
    badge="OTC 2025"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Green-screen matting"
    img="/research/greenmatting.webp"
    desc="Improving green-screen matting against color overflow and complex edges with group normalization and a perceptual loss. Published in The Visual Computer."
    url={matting}
    badge="The Visual Computer"
  />
</BaseLayout>
