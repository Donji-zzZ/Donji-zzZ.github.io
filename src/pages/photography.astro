---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image, getImage } from "astro:assets";
import nodePath from "node:path";
import photoMeta from "../data/photos";

// Auto-import every photo in src/images/photography/ AND its year subfolders.
const modules = import.meta.glob(
  [
    "../images/photography/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}",
    "../images/photography/**/*.{jpg,jpeg,png,webp,avif,JPG,JPEG,PNG,WEBP,AVIF}",
  ],
  { eager: true }
);

// optional EXIF reader (run `npm install exifr` to enable camera-setting captions)
let exifr: any = null;
try {
  const mod = "exifr";
  exifr = (await import(/* @vite-ignore */ mod)).default;
} catch (e) { /* not installed -> captions simply omit settings */ }

const baseName = (p: string) => p.split("/").pop() as string;
// the year is taken from the folder name (e.g. .../photography/2024/foo.jpg -> "2024")
const yearOf = (p: string) => {
  const segs = p.split("/");
  const parent = segs[segs.length - 2] || "";
  return /^\d{4}$/.test(parent) ? parent : null;
};
const fmtShutter = (s?: number) =>
  !s ? null : s >= 1 ? `${s}s` : `1/${Math.round(1 / s)}s`;
const cameraName = (make?: string, model?: string) => {
  let mk = (make || "").trim();
  let md = (model || "").trim();
  if (mk && mk === mk.toUpperCase()) mk = mk.charAt(0) + mk.slice(1).toLowerCase(); // SONY -> Sony
  if (!mk && !md) return null;
  if (md && mk && md.toLowerCase().startsWith(mk.toLowerCase())) return md;
  return [mk, md].filter(Boolean).join(" ");
};

const photos: any[] = [];
for (const [path, mod] of Object.entries(modules)) {
  const img = (mod as any).default;
  const file = baseName(path);
  const meta = (photoMeta as any)[file] || {};
  const year = yearOf(path);
  let settings: string | null = null;
  let camera: string | null = null;
  if (exifr) {
    try {
      const abs = nodePath.join(process.cwd(), "src/images/photography", path.split("/photography/")[1]);
      const ex = await exifr.parse(abs, ["Make", "Model", "FocalLength", "FNumber", "ExposureTime", "ISO"]);
      if (ex) {
        const parts: string[] = [];
        if (ex.FocalLength) parts.push(`${Math.round(ex.FocalLength)}mm`);
        if (ex.FNumber) parts.push(`f/${ex.FNumber}`);
        const sh = fmtShutter(ex.ExposureTime); if (sh) parts.push(sh);
        if (ex.ISO) parts.push(`ISO ${ex.ISO}`);
        settings = parts.join("  ·  ") || null;
        camera = cameraName(ex.Make, ex.Model);
      }
    } catch (e) { /* no exif on this file */ }
  }
  // append the (folder) year after ISO -- wide gap, no dot
  if (year) settings = settings ? `${settings}\u2003${year}` : year;

  const full = await getImage({
    src: img,
    width: Math.min(2400, img.width || 2400),
    quality: 85,
    format: "webp",
  });
  photos.push({
    full: full.src,
    img, file, year,
    location: meta.location || null,
    caption: meta.caption || null,
    alt: meta.alt || meta.caption || meta.location || "Photograph by Chenyu Zhou",
    camera, settings,
  });
}

// newest year first, then by filename
photos.sort((a, b) =>
  (b.year || "").localeCompare(a.year || "") || a.file.localeCompare(b.file)
);

const hasPhotos = photos.length > 0;
---

<BaseLayout title="Photography" sideBarActiveItemID="photography" wide={true}>
  <div class="mb-8">
    <div class="text-3xl w-full font-bold mb-2">Photography</div>
    <div class="text-lg opacity-90">
      Mostly landscapes and mountains — the same instinct as the science, pointed the other way:
      hold still, pay attention, and let the image resolve.{hasPhotos && " Tap any photo to enlarge."}
    </div>
  </div>

  {hasPhotos ? (
    <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4">
      {photos.map((p) => (
        <figure
          class="gallery-item mb-4 break-inside-avoid cursor-zoom-in group relative overflow-hidden rounded-lg bg-base-200"
          data-caption={[p.location, p.camera, p.settings].filter(Boolean).join("    ·    ")}
          data-full={p.full}
        >
          <Image
            src={p.img}
            alt={p.alt}
            widths={[400, 800, 1200, 1600, 2000]}
            sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, (max-width: 1280px) 33vw, 25vw"
            quality={82}
            loading="lazy"
            class="w-full h-auto block transition duration-300 group-hover:scale-[1.03]"
          />
          {(p.location || p.camera || p.settings) && (
            <figcaption class="absolute inset-x-0 bottom-0 p-3 text-white opacity-0 group-hover:opacity-100 transition bg-gradient-to-t from-black/70 to-transparent">
              {p.location && <span class="text-sm font-medium">{p.location}</span>}
              {p.camera && <span class="block text-xs opacity-90 font-mono">{p.camera}</span>}
              {p.settings && <span class="block text-xs opacity-80 font-mono">{p.settings}</span>}
            </figcaption>
          )}
        </figure>
      ))}
    </div>
  ) : (
    <div>
      <div class="bg-base-200 border-l-4 border-secondary p-4 mb-6">
        <p class="font-bold">No photos yet.</p>
        <p>
          Drop images into <code>src/images/photography/</code>, or into year subfolders
          like <code>2024/</code> and <code>2023/</code> to tag them with a year.
        </p>
      </div>
      <div class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-4 opacity-60">
        {[260, 200, 320, 180, 300, 220, 240, 280].map((h) => (
          <div class="mb-4 break-inside-avoid rounded-lg bg-base-200 animate-pulse" style={`height:${h}px`}></div>
        ))}
      </div>
    </div>
  )}

  <!-- Lightbox / viewer -->
  <div id="lightbox" class="fixed inset-0 hidden select-none" style="z-index:9999;background:rgba(0,0,0,0.97);">
    <div id="lb-counter" class="absolute top-4 left-5 z-20 text-white/70 text-sm font-mono pointer-events-none"></div>

    <div class="absolute top-3 right-4 z-20 flex items-center gap-1">
      <button id="lb-zoom" title="Zoom" class="p-2 rounded text-white/80 hover:text-white hover:bg-white/10">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3M11 8v6M8 11h6"/></svg>
      </button>
      <button id="lb-full" title="Full screen" class="p-2 rounded text-white/80 hover:text-white hover:bg-white/10">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3M16 3h3a2 2 0 0 1 2 2v3M21 16v3a2 2 0 0 1-2 2h-3M8 21H5a2 2 0 0 1-2-2v-3"/></svg>
      </button>
      <button id="lb-close" title="Close" class="p-2 rounded text-white/80 hover:text-white hover:bg-white/10">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12M18 6L6 18"/></svg>
      </button>
    </div>

    <div id="lb-stage" class="absolute inset-0 flex items-center justify-center overflow-hidden">
      <img id="lightbox-img" class="max-h-[88vh] max-w-[92vw] object-contain rounded" alt="" />
    </div>

    <button id="lb-prev" aria-label="Previous" class="lb-zone group absolute left-0 top-0 h-full w-[35%] flex items-center justify-start pl-3 cursor-pointer bg-transparent border-0">
      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/35 group-hover:text-white/90 transition"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button id="lb-next" aria-label="Next" class="lb-zone group absolute right-0 top-0 h-full w-[65%] flex items-center justify-end pr-3 cursor-pointer bg-transparent border-0">
      <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white/35 group-hover:text-white/90 transition"><path d="M9 18l6-6-6-6"/></svg>
    </button>

    <div id="lightbox-cap" class="absolute bottom-4 inset-x-0 z-20 text-center text-sm text-white/90 font-mono px-4 pointer-events-none"></div>
  </div>

  <script>
    function initViewer() {
      const lb = document.getElementById("lightbox") as HTMLElement | null;
      const figs = Array.from(document.querySelectorAll(".gallery-item"));
      if (!lb || figs.length === 0) return;
      if (lb.dataset.lbReady === "1") return;   // this element already wired up
      lb.dataset.lbReady = "1";

      document.body.style.overflow = "";        // reset in case we navigated away while open
      // drop any stale overlay left on <body> by a previous visit
      document.querySelectorAll("body > #lightbox").forEach((el) => { if (el !== lb) el.remove(); });
      // relocate THIS overlay to <body> so `fixed inset-0` truly fills the viewport
      if (lb.parentElement !== document.body) document.body.appendChild(lb);

      const lbImg = lb.querySelector("#lightbox-img") as HTMLImageElement;
      const lbCap = lb.querySelector("#lightbox-cap") as HTMLElement;
      const lbCounter = lb.querySelector("#lb-counter") as HTMLElement;
      const stage = lb.querySelector("#lb-stage") as HTMLElement;
      const zones = Array.from(lb.querySelectorAll(".lb-zone")) as HTMLElement[];
      let idx = 0;
      let zoomed = false;

      function setZoom(on: boolean) {
        zoomed = on;
        if (on) {
          lbImg.className = "max-w-none max-h-none m-auto cursor-zoom-out";
          stage.className = "absolute inset-0 flex overflow-auto";
          zones.forEach((z) => z.classList.add("pointer-events-none"));
        } else {
          lbImg.className = "max-h-[88vh] max-w-[92vw] object-contain rounded";
          stage.className = "absolute inset-0 flex items-center justify-center overflow-hidden";
          zones.forEach((z) => z.classList.remove("pointer-events-none"));
        }
      }
      function render() {
        const fig = figs[idx];
        const img = fig.querySelector("img") as HTMLImageElement | null;
        lbImg.src = fig.getAttribute("data-full") || (img && (img.currentSrc || img.src)) || "";
        lbImg.alt = (img && img.alt) || "";
        lbCap.textContent = fig.getAttribute("data-caption") || "";
        lbCounter.textContent = (idx + 1) + " / " + figs.length;
        setZoom(false);
        stage.scrollTo(0, 0);
      }
      function openAt(i: number) {
        idx = i;
        lb.classList.remove("hidden");
        document.body.style.overflow = "hidden";
        render();
      }
      function closeLb() {
        lb.classList.add("hidden");
        lbImg.src = "";
        document.body.style.overflow = "";
        if (document.fullscreenElement) document.exitFullscreen().catch(() => {});
      }
      function go(d: number) { idx = (idx + d + figs.length) % figs.length; render(); }

      figs.forEach((f, i) => f.addEventListener("click", () => openAt(i)));
      (lb.querySelector("#lb-prev") as HTMLElement).addEventListener("click", () => go(-1));
      (lb.querySelector("#lb-next") as HTMLElement).addEventListener("click", () => go(1));
      (lb.querySelector("#lb-close") as HTMLElement).addEventListener("click", closeLb);
      (lb.querySelector("#lb-zoom") as HTMLElement).addEventListener("click", () => setZoom(!zoomed));
      (lb.querySelector("#lb-full") as HTMLElement).addEventListener("click", () => {
        if (!document.fullscreenElement) { if (lb.requestFullscreen) lb.requestFullscreen(); }
        else if (document.exitFullscreen) document.exitFullscreen();
      });
      lbImg.addEventListener("click", () => { if (zoomed) setZoom(false); });

      // expose the live controller for the single global key/resize handlers
      (window as any).__lb = {
        go, closeLb,
        resetZoom: () => setZoom(false),
        isOpen: () => !lb.classList.contains("hidden"),
      };
    }

    // global handlers, bound exactly once (they read whatever the current viewer is)
    if (!(window as any).__lbGlobals) {
      (window as any).__lbGlobals = true;
      document.addEventListener("keydown", (e) => {
        const c = (window as any).__lb;
        if (!c || !c.isOpen()) return;
        if (e.key === "Escape") c.closeLb();
        else if (e.key === "ArrowRight") c.go(1);
        else if (e.key === "ArrowLeft") c.go(-1);
      });
      window.addEventListener("resize", () => {
        const c = (window as any).__lb;
        if (c && c.isOpen()) c.resetZoom();   // snap back to fit on resize
      });
    }

    // run on first load AND after every View-Transitions navigation
    document.addEventListener("astro:page-load", initViewer);
    if (document.readyState !== "loading") initViewer();
    else document.addEventListener("DOMContentLoaded", initViewer);
  </script>
</BaseLayout>
